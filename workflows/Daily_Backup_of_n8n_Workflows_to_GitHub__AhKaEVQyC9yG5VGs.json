      "id": "433854ec-5f36-40c2-b2a8-76e1e69a64e9",
      "name": "List n8n Workflows",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        464,
        400
      ],
      "credentials": {
        "httpHeaderAuth": {
          "id": "d9womSSWKUI19oC2",
          "name": "n8n API Key"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst results = [];\nfor (const item of items) {\n  const list = (item.json && Array.isArray(item.json.data)) ? item.json.data : [];\n  for (const wf of list) {\n    if (wf.isArchived === true) continue;\n    const safeName = String(wf.name || wf.id)\n      .replace(/[\\\\/:*?\"<>|]+/g, \"_\")\n      .replace(/\\s+/g, \"_\")\n      .replace(/_+/g, \"_\")\n      .replace(/^_+|_+$/g, \"\")\n      .slice(0, 100);\n    results.push({\n      json: {\n        id: wf.id,\n        name: wf.name,\n        active: wf.active === true,\n        isArchived: wf.isArchived === true,\n        filename: \"workflows/\" + safeName + \"__\" + wf.id + \".json\"\n      }\n    });\n  }\n}\nreturn results;"
      },
      "id": "e0cecff2-3aa6-46b4-b00a-c517537f17a3",
      "name": "Filter and Prep Workflows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        400
      ],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const prepItems = $(\"Prepare Commit\").all();\nconst commitItems = $(\"Commit to GitHub\").all();\nlet success = 0;\nlet skipped = 0;\nconst failures = [];\nfor (let i = 0; i < prepItems.length; i++) {\n  const prep = prepItems[i] && prepItems[i].json ? prepItems[i].json : {};\n  const commit = commitItems[i] && commitItems[i].json ? commitItems[i].json : {};\n  const fname = prep.filename || \"unknown\";\n  if (prep.skip === true) {\n    skipped += 1;\n    failures.push({ file: fname, error: prep.skipReason || \"skipped\" });\n    continue;\n  }\n  const ok = (commit && commit.commit && typeof commit.commit.sha === \"string\");\n  if (ok) {\n    success += 1;\n  } else {\n    let msg = \"Unknown error\";\n    if (commit && commit.error) {\n      msg = (commit.error.message || JSON.stringify(commit.error)).toString().slice(0, 200);\n    } else if (commit && commit.message) {\n      msg = String(commit.message).slice(0, 200);\n    }\n    failures.push({ file: fname, error: msg });\n  }\n}\nconst total = prepItems.length;\nconst failed = failures.length;\nconst status = failed === 0 ? \"success\" : (success === 0 ? \"failure\" : \"partial\");\nconst icon = status === \"success\" ? \":white_check_mark:\" : (status === \"partial\" ? \":warning:\" : \":x:\");\nconst dateStr = new Date().toISOString().slice(0, 10);\nlet message = icon + \" *n8n Backup \" + dateStr + \"* — \" + success + \"/\" + total + \" workflows committed to `antonioefm/n8nbackup`\";\nif (failed > 0) {\n  message += \"\\n\\n*Issues (\" + failed + \"):*\\n\";\n  const shown = failures.slice(0, 10);\n  for (const f of shown) {\n    message += \"• `\" + f.file + \"`: \" + f.error + \"\\n\";\n  }\n  if (failed > 10) message += \"_…and \" + (failed - 10) + \" more_\";\n}\nreturn [{ json: { status: status, success: success, failed: failed, skipped: skipped, total: total, message: message } }];"
      },
