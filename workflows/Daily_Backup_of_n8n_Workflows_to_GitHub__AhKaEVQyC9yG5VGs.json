    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const wfMeta = $(\"Loop Over Workflows\").item.json;\nconst wfFull = $(\"Fetch Workflow JSON\").item.json;\nconst shaItem = $json;\nconst fetchOk = wfFull && typeof wfFull.id === \"string\" && Array.isArray(wfFull.nodes);\nconst existingSha = (shaItem && typeof shaItem.sha === \"string\") ? shaItem.sha : null;\nconst dateStr = new Date().toISOString().slice(0, 10);\nif (!fetchOk) {\n  return {\n    filename: wfMeta.filename,\n    workflowName: wfMeta.name,\n    workflowId: wfMeta.id,\n    skip: true,\n    skipReason: \"Workflow fetch failed\",\n    bodyJson: \"{}\"\n  };\n}\nconst content = Buffer.from(JSON.stringify(wfFull, null, 2), \"utf8\").toString(\"base64\");\nconst bodyObj = {\n  message: \"Daily backup \" + dateStr + \" - \" + wfMeta.name,\n  content: content,\n  branch: \"main\"\n};\nif (existingSha) bodyObj.sha = existingSha;\nreturn {\n  filename: wfMeta.filename,\n  workflowName: wfMeta.name,\n  workflowId: wfMeta.id,\n  skip: false,\n  bodyJson: JSON.stringify(bodyObj)\n};"
      },
