    {
      "parameters": {
        "jsCode": "const currentTicketId = $('Restore trigger data').first().json.body['ticket.id'];\nconst tickets = $input.first().json.tickets || [];\n\n// Any OTHER ticket for this requester, regardless of status.\nconst otherTickets = tickets.filter(t => String(t.id) !== String(currentTicketId));\n\nconst proceed = otherTickets.length === 0;\n\nreturn [{\n  json: {\n    proceed,\n    unhandled_ticket_count: otherTickets.length,        // key kept so the note node still works\n    other_unhandled_ticket_ids: otherTickets.map(t => t.id)\n  }\n}];"
      },
