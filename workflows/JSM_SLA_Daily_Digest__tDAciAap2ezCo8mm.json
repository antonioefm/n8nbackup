          "jsCode": "const output = [];\n\nconst slackItems = $('Slack lookup by email').all();\nconst assigneeItems = $('Split Out').all();\n\nfor (let i = 0; i < slackItems.length; i++) {\n  const slackResponse = slackItems[i].json;\n  const assignee = assigneeItems[i].json;\n\n  if (!slackResponse.ok || !slackResponse.user?.id) {\n    console.log(`Slack lookup failed for ${assignee.email}: ${slackResponse.error || JSON.stringify(slackResponse)}`);\n    continue;\n  }\n\n  const slackUserId = slackResponse.user.id;\n  const firstName = assignee.displayName.split(' ')[0];\n\n  const sections = [];\n\n  if (assignee.breached.length > 0) {\n    const lines = assignee.breached.map(t =>\n      `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n    ).join('\\n');\n    sections.push(`:red_circle: *Breached SLA — Time to Resolution*\\n${lines}`);\n  }\n\n  if (assignee.inactive.length > 0) {\n    const lines = assignee.inactive.map(t =>\n      `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n    ).join('\\n');\n    sections.push(`:large_yellow_circle: *No activity in the last 24h*\\n${lines}`);\n  }\n\n  if (sections.length === 0) continue;\n\n  const message = `Hello ${firstName}, here is your daily IT ticket digest:\\n\\n` + sections.join('\\n\\n') + '\\n\\n_Please review and action these tickets today._';\n\n  output.push({ json: { slackUserId, message } });\n}\n\nreturn output;"
        },
