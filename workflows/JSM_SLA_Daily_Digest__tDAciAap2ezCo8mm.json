    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst unassignedBreached = data.unassignedBreached || [];\nconst unassignedInactive = data.unassignedInactive || [];\n\nif (unassignedBreached.length === 0 && unassignedInactive.length === 0) {\n  return [{ json: { skip: true, message: '' } }];\n}\n\nconst sections = [];\n\nif (unassignedBreached.length > 0) {\n  const lines = unassignedBreached.map(t =>\n    `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n  ).join('\\n');\n  sections.push(`:red_circle: *Unassigned — Breached SLA*\\n${lines}`);\n}\n\nif (unassignedInactive.length > 0) {\n  const lines = unassignedInactive.map(t =>\n    `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n  ).join('\\n');\n  sections.push(`:large_yellow_circle: *Unassigned — No activity in the last 24h*\\n${lines}`);\n}\n\nconst message = `Daily IT ticket digest — unassigned tickets needing attention:\\n\\n` + sections.join('\\n\\n') + '\\n\\n_Please assign and action these tickets._';\n\nreturn [{ json: { skip: false, message } }];"
      },
