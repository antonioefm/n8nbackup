      "id": "0eacd6ae-9f99-44cd-8291-f67e6134587e",
      "name": "Fetch inactive IT issues",
      "type": "n8n-nodes-base.jira",
      "typeVersion": 1,
      "position": [
        -864,
        560
      ],
      "credentials": {
        "jiraSoftwareCloudApi": {
          "id": "vXyadK9bOxpEt9lU",
          "name": "Jira API Antonio token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const breachedItems = $('Fetch breached IT issues').all();\nconst inactiveItems = $('Fetch inactive IT issues').all();\n\nfunction parseIssue(item) {\n  const issue = item.json;\n  const key = issue.key;\n  const fields = issue.fields || {};\n  return {\n    key,\n    summary: fields.summary || '(no summary)',\n    priority: fields.priority?.name || 'Unknown',\n    status: fields.status?.name || 'Unknown',\n    url: `https://futuremedia.atlassian.net/browse/${key}`,\n    assigneeEmail: fields.assignee?.emailAddress || null,\n    assigneeDisplay: fields.assignee?.displayName || null,\n    updated: fields.updated || null\n  };\n}\n\nconst breachedKeys = new Set(breachedItems.map(i => i.json.key));\n\nconst assigned = {};\nconst unassignedBreached = [];\nconst unassignedInactive = [];\n\nfor (const item of breachedItems) {\n  const t = parseIssue(item);\n  const ticket = { key: t.key, summary: t.summary, priority: t.priority, status: t.status, url: t.url };\n  if (t.assigneeEmail) {\n    if (!assigned[t.assigneeEmail]) {\n      assigned[t.assigneeEmail] = { displayName: t.assigneeDisplay, email: t.assigneeEmail, breached: [], inactive: [] };\n    }\n    assigned[t.assigneeEmail].breached.push(ticket);\n  } else {\n    unassignedBreached.push(ticket);\n  }\n}\n\nfor (const item of inactiveItems) {\n  const t = parseIssue(item);\n  if (breachedKeys.has(t.key)) continue;\n  const ticket = { key: t.key, summary: t.summary, priority: t.priority, status: t.status, url: t.url, updated: t.updated };\n  if (t.assigneeEmail) {\n    if (!assigned[t.assigneeEmail]) {\n      assigned[t.assigneeEmail] = { displayName: t.assigneeDisplay, email: t.assigneeEmail, breached: [], inactive: [] };\n    }\n    assigned[t.assigneeEmail].inactive.push(ticket);\n  } else {\n    unassignedInactive.push(ticket);\n  }\n}\n\nreturn [{ json: { assigned: Object.values(assigned), unassignedBreached, unassignedInactive } }];"
      },
