  "nodes": [
    {
      "parameters": {
        "operation": "getAll",
        "returnAll": true,
        "options": {
          "fields": "summary,assignee,priority,status",
          "jql": "project = IT AND statusCategory != Done AND \"Time to resolution\" = breached() ORDER BY assignee ASC"
        }
      },
      "id": "6b753769-a1a9-4e5e-af35-6138d63146ea",
      "name": "Fetch breached IT issues",
      "type": "n8n-nodes-base.jira",
      "typeVersion": 1,
      "position": [
        -3744,
        1840
      ],
      "credentials": {
        "jiraSoftwareCloudApi": {
          "id": "vXyadK9bOxpEt9lU",
          "name": "Jira API Antonio token"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const issues = $input.all();\n\nconst assigned = {};\nconst unassigned = [];\n\nfor (const item of issues) {\n  const issue = item.json;\n  const key = issue.key;\n  const summary = issue.fields?.summary || '(no summary)';\n  const priority = issue.fields?.priority?.name || 'Unknown';\n  const status = issue.fields?.status?.name || 'Unknown';\n  const url = `https://futuremedia.atlassian.net/browse/${key}`;\n  const assignee = issue.fields?.assignee;\n\n  const ticket = { key, summary, priority, status, url };\n\n  if (assignee && assignee.emailAddress) {\n    const email = assignee.emailAddress;\n    const displayName = assignee.displayName;\n    if (!assigned[email]) {\n      assigned[email] = { displayName, email, tickets: [] };\n    }\n    assigned[email].tickets.push(ticket);\n  } else {\n    unassigned.push(ticket);\n  }\n}\n\nreturn [{ json: { assigned: Object.values(assigned), unassigned } }];"
      },
      "id": "7ccd687b-227f-4dd9-9328-34c302b73cfc",
      "name": "Group by assignee",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -3520,
        1840
      ]
    },
    {
      "parameters": {
        "fieldToSplitOut": "assigned",
        "options": {}
      },
      "id": "523871ad-c87e-4291-b92e-71417c23cf26",
      "name": "Split Out",
      "type": "n8n-nodes-base.splitOut",
      "typeVersion": 1,
      "position": [
        -3296,
        1744
      ]
    },
    {
      "parameters": {
        "url": "https://slack.com/api/users.lookupByEmail",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBearerAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            {
              "name": "email",
              "value": "={{ $json.email }}"
            }
          ]
        },
        "options": {}
      },
      "id": "ffc7b610-d99b-4ed2-947a-8ab3ac23f3aa",
      "name": "Slack lookup by email",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -3072,
        1744
      ],
      "credentials": {
        "httpBearerAuth": {
          "id": "lOzgmJyjkThz1Dhx",
          "name": "Slack FM bot"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const output = [];\n\nconst slackItems = $('Slack lookup by email').all();\nconst assigneeItems = $('Split Out').all();\n\nfor (let i = 0; i < slackItems.length; i++) {\n  const slackResponse = slackItems[i].json;\n  const assignee = assigneeItems[i].json;\n\n  if (!slackResponse.ok || !slackResponse.user?.id) {\n    console.log(`Slack lookup failed for ${assignee.email}: ${slackResponse.error || JSON.stringify(slackResponse)}`);\n    continue;\n  }\n\n  const slackUserId = slackResponse.user.id;\n  const firstName = assignee.displayName.split(' ')[0];\n\n  const lines = assignee.tickets.map(t =>\n    `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n  ).join('\\n');\n\n  const message = `:warning: *SLA Breach Digest — Time to Resolution*\\n\\nHi ${firstName}, the following tickets assigned to you have breached their resolution SLA and need attention today:\\n\\n${lines}\\n\\n_Please update or escalate these tickets as soon as possible._`;\n\n  output.push({ json: { slackUserId, message } });\n}\n\nreturn output;"
      },
      "id": "77bb9c6f-477c-4d89-a2aa-56e2068a7945",
      "name": "Build DM message",
      "type": "n8n-nodes-base.code",
