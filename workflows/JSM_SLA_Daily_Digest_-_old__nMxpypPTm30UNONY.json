    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst unassigned = data.unassigned || [];\n\nif (unassigned.length === 0) {\n  return [{ json: { skip: true, message: '' } }];\n}\n\nconst lines = unassigned.map(t =>\n  `• <${t.url}|${t.key}> — ${t.summary} _(${t.priority})_`\n).join('\\n');\n\nconst message = `:warning: *Unassigned SLA Breaches — Time to Resolution*\\n\\nThe following tickets are unassigned and have breached their resolution SLA:\\n\\n${lines}\\n\\n_Please assign and action these tickets._`;\n\nreturn [{ json: { skip: false, message } }];"
      },
