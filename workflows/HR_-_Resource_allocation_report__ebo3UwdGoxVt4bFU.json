      "name": "Data cleanup subworkflow"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst startDate = new Date(items[0]?.json[\"Start date\"]);\nconst endDate = new Date(items[0]?.json[\"End date\"]);\nconst dateChunks = [];\n\nwhile (startDate < endDate) {\n  const chunkEnd = new Date(startDate);\n  chunkEnd.setDate(chunkEnd.getDate() + 4);\n  if (chunkEnd > endDate) {\n    chunkEnd.setDate(endDate.getDate());\n  }\n\n  dateChunks.push({\n    start: startDate.toISOString().split(\"T\")[0],\n    end: chunkEnd.toISOString().split(\"T\")[0],\n  });\n\n  startDate.setDate(startDate.getDate() + 5);\n}\n\nreturn dateChunks.map((chunk, index) => ({ json: chunk, pairedItem: index }));\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -208,
        2784
      ],
      "id": "f5f61b4f-3568-46f4-916a-fa0713c66461",
      "name": "Split date range into 5 day chunks"
    },
    {
      "parameters": {
        "jsCode": "// n8n Code node\n// Input: items = [{ json: { projectName, appended_userName } }, ...]\n\nconst formattedText = $input.all().map(({ json }) => {\n    const projectName = json.projectName ?? '';\n    const users = Array.isArray(json.appended_userName)\n      ? json.appended_userName\n      : [];\n\n    const userLines = users.map(user => `  - ${user}`).join('\\n');\n\n    return `- ${projectName}\\n${userLines}`;\n  })\n  .join('\\n\\n');\n\n// Return a single item so it's easy to use in Email / Gmail nodes\nreturn [\n  {\n    json: {\n      formattedText,\n    },\n  },\n];\n"
      },
