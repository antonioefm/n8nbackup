    {
      "parameters": {
        "jsCode": "// === Check if a transaction ID is in the refundedTransactions array ===\n// Mode: \"Run Once for All Items\".\n\nconst body = ($input.first()?.json ?? {}).body ?? {};\n\n// 1) The ID to look for.\nconst targetId = String(body.transactionId ?? '').trim().toLowerCase();\n\n// 2) The array to search.\nconst refunded = body.refundedTransactions ?? [];\nconst list = Array.isArray(refunded) ? refunded : [];\n\n// 3) First element whose top-level id matches (provider.id is ignored).\nconst match = targetId\n  ? list.find((el) => String(el?.id ?? '').trim().toLowerCase() === targetId)\n  : undefined;\n\n// 4) Output the decision (+ the matched element, for logging/branching).\nreturn [{\n  json: {\n    targetId,\n    found: !!match,\n    matchedTransaction: match ?? null,\n  },\n}];\n"
      },
